# Piston API Configuration
# All variables are prefixed with PISTON_

# Port to bind the API on
PISTON_BIND_ADDRESS=0.0.0.0:2000

# Level of data to log (ERROR, WARN, INFO, DEBUG)
PISTON_LOG_LEVEL=INFO

# Absolute path to store all piston related data at
PISTON_DATA_DIRECTORY=/piston

# URL of the package repository index
PISTON_REPO_URL=https://github.com/engineer-man/piston/releases/download/pkgs/index

# Maximum number of concurrent jobs
PISTON_MAX_CONCURRENT_JOBS=64

# Networking toggle for jobs
PISTON_DISABLE_NETWORKING=true

# Language Packages to install on startup (comma-separated)
# Format: language or language=version
# Example: bash,python=3.10.0,node=20.11.1
PISTON_INSTALL_PACKAGES=gcc,typescript,python,node

# Available Languages in packages directory:
# - bash
# - gcc (10.2.0)
# - go
# - java
# - node (20.11.1)
# - php
# - python (3.12.0)
# - rust
# - typescript (5.0.3)
